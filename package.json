{
  "name": "baby-tracker",
  "version": "1.3.4",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "prisma:prepare": "node scripts/prisma-provider.js",
    "prisma:generate": "npm run prisma:prepare && prisma generate",
    "prisma:generate:log": "npm run prisma:prepare && prisma generate --schema=prisma/log-schema.prisma",
    "prisma:migrate": "prisma migrate dev",
    "prisma:push:log": "prisma db push --schema=prisma/log-schema.prisma",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "prisma:studio:log": "prisma studio --schema=prisma/log-schema.prisma",
    "prisma:seed": "ts-node --project prisma/tsconfig.json prisma/seed.ts",
    "setup:vapid": "tsx scripts/setup-vapid-keys.ts",
    "notification:cron:setup": "tsx scripts/setup-notification-cron.ts",
    "notification:cron:run": "bash scripts/run-notification-cron.sh",
    "env:ensure": "node scripts/ensure-env-defaults.js"
  },
  "dependencies": {
    "@lucide/lab": "^0.1.2",
    "@mdi/js": "^7.4.47",
    "@mdi/react": "^1.6.1",
    "@prisma/client": "^6.19.1",
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-dropdown-menu": "^2.1.6",
    "@radix-ui/react-hover-card": "^1.1.6",
    "@radix-ui/react-label": "^2.1.2",
    "@radix-ui/react-popover": "^1.1.6",
    "@radix-ui/react-select": "^2.1.6",
    "@radix-ui/react-separator": "^1.1.2",
    "@radix-ui/react-slot": "^1.1.2",
    "@sendgrid/mail": "^8.1.5",
    "@stripe/stripe-js": "^8.2.0",
    "@tanstack/react-query": "^5.74.4",
    "@tanstack/react-query-devtools": "^5.74.4",
    "better-sqlite3": "^12.8.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "exceljs": "^4.4.0",
    "framer-motion": "^12.5.0",
    "html2canvas-pro": "^2.0.2",
    "jsonwebtoken": "^9.0.2",
    "jspdf": "^4.2.1",
    "jszip": "^3.10.1",
    "lucide-react": "^0.475.0",
    "next": "^16.0.10",
    "nodemailer": "^7.0.5",
    "prisma": "^6.3.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^3.6.0",
    "sharp": "^0.34.5",
    "stripe": "^19.2.0",
    "tailwind-merge": "^3.0.1",
    "tailwindcss-animate": "^1.0.7",
    "web-push": "^3.6.7"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "devDependencies": {
    "@shadcn/ui": "^0.0.4",
    "@tailwindcss/nesting": "^0.0.0-insiders.565cd3e",
    "@tailwindcss/postcss": "^4.0.17",
    "@types/better-sqlite3": "^7.6.13",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/jszip": "^3.4.0",
    "@types/node": "^22.14.1",
    "@types/nodemailer": "^6.4.17",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "@types/sharp": "^0.31.1",
    "@types/web-push": "^3.6.4",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.20.1",
    "eslint-config-next": "^15.1.7",
    "postcss": "^8.5.2",
    "postcss-import": "^16.1.0",
    "tailwindcss": "^4.0.6",
    "ts-node": "^10.9.2",
    "tsx": "^4.20.3",
    "typescript": "^5.7.3"
  }
